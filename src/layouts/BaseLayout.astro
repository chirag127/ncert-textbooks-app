---
/*
 * BaseLayout — v2 dark catalogue surface.
 *
 * Chrome composition (per locked policy):
 *   - Header:    LOCAL (~/components/Header.astro) — fully divergent per-app
 *                with class/subject filter toggle for the home filter rail.
 *   - Sidebar:   @chirag127/astro-chrome/Sidebar.astro — shared drawer shell,
 *                per-app slot content (AppSidebarContent → class/subject nav).
 *   - Footer:    @chirag127/astro-chrome/Footer.astro — shared mega-sitemap.
 *   - BottomBar: @chirag127/astro-chrome/BottomBar.astro — shared structure,
 *                per-app icons (Home/Classes/Search/Downloads/Menu).
 */
import '~/styles/global.css'
import '~/styles/oriz-ui-overrides.css'
import '@chirag127/astro-shell/tokens.css'
import Header from '~/components/Header.astro'
import AppSidebarContent from '~/components/AppSidebarContent.astro'
import Sidebar from '@chirag127/astro-chrome/Sidebar.astro'
import Footer from '@chirag127/astro-chrome/Footer.astro'
import BottomBar from '@chirag127/astro-chrome/BottomBar.astro'
import { SITE_CONFIG } from '~/lib/siteConfig'
import { bottomBarActions } from '~/data/bottombar-actions'

interface Props {
  title?: string
  description?: string
  canonical?: string
  noindex?: boolean
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
  /** Hide the header (account/finish-sign-in or other distraction-free flows). */
  hideHeader?: boolean
}

const {
  title = `${SITE_CONFIG.name} — ${SITE_CONFIG.tagline}`,
  description = SITE_CONFIG.description ?? SITE_CONFIG.tagline,
  canonical = `${SITE_CONFIG.origin}${Astro.url.pathname}`,
  noindex = false,
  jsonLd,
  hideHeader = false,
} = Astro.props

const beaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={`${SITE_CONFIG.name} — oriz`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@chirag127" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:ital,wght@0,400;0,500;0,600;1,400&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Sans+Devanagari:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    {
      jsonLd && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])}
        />
      )
    }

    {
      beaconToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${beaconToken}"}`}
        />
      )
    }
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    {hideHeader ? (
      <main id="main"><slot /></main>
    ) : (
      <>
        <Header />
        <div class="layout-body">
          <Sidebar>
            <AppSidebarContent />
          </Sidebar>
          <main id="main" class="layout-main"><slot /></main>
        </div>
        <Footer />
        <BottomBar actions={bottomBarActions} />
      </>
    )}
    <style>
      .layout-body { display: flex; align-items: flex-start; }
      .layout-main { flex: 1 1 auto; min-width: 0; min-height: 50vh; }
      @media (max-width: 767px) {
        .layout-body { display: block; }
        .layout-main { padding-bottom: 64px; }
      }
    </style>
  </body>
</html>
