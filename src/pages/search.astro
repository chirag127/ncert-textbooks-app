---
import BookSearch from '~/components/BookSearch.tsx'
import BaseLayout from '~/layouts/BaseLayout.astro'
---

<BaseLayout
  title="Search — Books"
  description="Full-text search across the NCERT textbook directory."
>
  <div class="spine">
    <header class="page-head">
      <p class="eyebrow"><a href="/">CATALOGUE</a> / SEARCH</p>
      <h1>Search the catalogue.</h1>
      <p class="lede">
        Find a textbook by title, subject, class, chapter name, or keyword —
        Hindi titles match Devanagari and Latin transliterations alike.
      </p>
    </header>

    <BookSearch client:load />
  </div>
</BaseLayout>
