---
import BaseLayout from '~/layouts/BaseLayout.astro'
import BookSearch from '~/components/BookSearch.tsx'
---

<BaseLayout
  title="Search — Books"
  description="Full-text search across the NCERT textbook directory."
>
  <header class="container-page page-head">
    <p class="eyebrow"><a href="/">Books</a> / Search</p>
    <h1>Search</h1>
    <p class="lede">
      Find a textbook by title, subject, class, chapter name, or keyword.
    </p>
  </header>

  <section class="container-page page-body">
    <BookSearch client:load />
  </section>
</BaseLayout>

<style>
  .page-head { padding-block: 2.5rem 1.25rem; border-bottom: 1px solid var(--color-border); }
  .eyebrow { color: var(--color-fg-muted); font-size: 0.8125rem; margin: 0 0 0.5rem; }
  .eyebrow a { color: var(--color-fg-muted); text-decoration: none; }
  h1 { font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 2.5rem); font-weight: 600; margin: 0; }
  .lede { color: var(--color-fg-muted); margin: 0.5rem 0 0; max-width: 56ch; }
  .page-body { padding-block: 1.5rem 4rem; }
</style>
