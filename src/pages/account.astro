---
import AccountPanel from '~/components/AccountPanel.tsx'
import BaseLayout from '~/layouts/BaseLayout.astro'
---

<BaseLayout
  title="Account — Books"
  description="Sign in to oriz. One account works across every oriz site."
  noindex={true}
>
  <div class="spine-prose">
    <header class="page-head">
      <p class="eyebrow"><a href="/">CATALOGUE</a> / ACCOUNT</p>
      <h1>Account.</h1>
      <p class="lede">
        One sign-in works across every oriz site. Bookmarks and reading
        history follow you.
      </p>
    </header>

    <section class="account-section">
      <AccountPanel client:load siteName="Books" />
    </section>
  </div>
</BaseLayout>

<style>
  .account-section {
    padding-block: 2.5rem 4rem;
  }
</style>
