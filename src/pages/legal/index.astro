---
import BaseLayout from '~/layouts/BaseLayout.astro'

const sections = [
  {
    slug: 'privacy',
    label: 'Privacy policy',
    desc: "What we collect, what we don't, your rights.",
  },
  { slug: 'terms', label: 'Terms of use', desc: 'The rules for using books.oriz.in.' },
  {
    slug: 'disclaimer',
    label: 'Disclaimer',
    desc: "Books links to NCERT — we don't host their PDFs.",
  },
  { slug: 'cookies', label: 'Cookie policy', desc: 'What cookies and localStorage we set.' },
  { slug: 'grievance', label: 'Grievance officer', desc: 'Mandatory contact under IT Rules 2021.' },
]
---

<BaseLayout
  title="Legal — Books"
  description="Privacy, terms, and grievance contact for books.oriz.in."
>
  <div class="spine-prose">
    <header class="page-head">
      <p class="eyebrow"><a href="/">CATALOGUE</a> / LEGAL</p>
      <h1>Legal.</h1>
    </header>

    <section class="legal-section">
      <ul class="legal-list">
        {
          sections.map((s) => (
            <li>
              <a href={`/legal/${s.slug}/`} class="legal-card">
                <h2>{s.label}</h2>
                <p>{s.desc}</p>
                <span class="arrow mono" aria-hidden="true">→</span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .legal-section {
    padding-block: 2rem 4rem;
  }
  .legal-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--rule);
  }
  .legal-list li {
    margin: 0;
  }
  .legal-card {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 0.5rem;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    border-left: 2px solid transparent;
  }
  .legal-card:hover {
    background: color-mix(in oklab, var(--brass) 8%, transparent);
    border-left-color: var(--cinnabar);
  }
  .legal-card h2 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.0625rem;
    color: var(--ink);
  }
  .legal-card p {
    margin: 0.25rem 0 0;
    color: var(--ink-mute);
    font-size: 0.9375rem;
  }
  .legal-card .arrow {
    color: var(--ink-mute);
    font-family: var(--font-mono);
  }
  .legal-card:hover .arrow {
    color: var(--cinnabar);
  }
</style>
