---
import BaseLayout from '~/layouts/BaseLayout.astro'

/*
 * Contact — restyled for v2.
 *
 * Drops the @chirag127/oriz-ui ContactForm (which carried v1 token coupling).
 * The form posts directly to Web3Forms via plain HTML — no React island
 * needed for a simple form. We render a small client-side handler inline
 * to give the user feedback after submission, and emit `data-oriz-contact-*`
 * hooks so the styles in oriz-ui-overrides.css apply.
 */
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? ''
---

<BaseLayout
  title="Contact — Books"
  description="Get in touch about the oriz Books library."
>
  <div class="spine-prose">
    <header class="page-head">
      <p class="eyebrow"><a href="/">CATALOGUE</a> / CONTACT</p>
      <h1>Contact.</h1>
    </header>

    <section class="prose">
      <p class="lede">
        Spotted a wrong link, a missing book, or a chapter that won't download
        from <a href="https://ncert.nic.in/">ncert.nic.in</a>? Tell me about it.
      </p>
      <p>
        Email is fastest:
        <a href="mailto:whyiswhen@gmail.com"><strong>whyiswhen@gmail.com</strong></a>.
        Or use the form below — it posts to Web3Forms, which forwards the
        message to my inbox. We don't store anything on books.oriz.in.
      </p>

      <form
        data-oriz-contact
        action="https://api.web3forms.com/submit"
        method="POST"
      >
        <input type="hidden" name="access_key" value={web3formsKey} />
        <input type="hidden" name="from_name" value="books.oriz.in" />
        <input type="hidden" name="subject" value="books.oriz.in contact form" />
        <input type="checkbox" name="botcheck" style="display: none;" tabindex="-1" autocomplete="off" />

        <label for="cf-name">Name</label>
        <input id="cf-name" name="name" type="text" required autocomplete="name" />

        <label for="cf-email">Email</label>
        <input id="cf-email" name="email" type="email" required autocomplete="email" />

        <label for="cf-msg">Message</label>
        <textarea id="cf-msg" name="message" rows="5" required></textarea>

        <button type="submit">Send</button>

        <p data-oriz-contact-status aria-live="polite"></p>
      </form>

      <p class="meta-foot">
        For privacy questions or DMCA notices, see the
        <a href="/legal/grievance/">grievance officer</a> page (mandatory under
        India's IT Rules 2021).
      </p>
    </section>
  </div>
</BaseLayout>

<style>
  .meta-foot {
    font-size: 0.875rem;
    color: var(--ink-mute);
    margin-top: 2rem;
  }
</style>
