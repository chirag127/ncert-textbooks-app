---
import BookGrid from '~/components/BookGrid.tsx'
/*
 * Home — catalogue-card grid on the wooden desk surface.
 *
 * Per the v2 brief:
 *   - Filter rail left (Class, Subject, Medium with subject swatches)
 *   - Card grid right, 5×3 cards on a typical viewport, 280×168 catalogue
 *     ratio, 24px gap
 *   - Eyebrow + page title `Class — Subject` style above the grid (the
 *     spec calls for `Class 8 — Science` H1 styling but on the index we
 *     use the catalogue title)
 *
 * NO hero illustration of stacked books, NO graduation cap, NO "Featured /
 * Trending" carousel. This page IS the catalogue.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'
import { SITE_CONFIG } from '~/lib/siteConfig'

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_CONFIG.name,
  url: SITE_CONFIG.origin,
  description: SITE_CONFIG.description,
  publisher: { '@type': 'Person', name: 'Chirag Singhal' },
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE_CONFIG.origin}/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
}
---

<BaseLayout
  title={`${SITE_CONFIG.name} — ${SITE_CONFIG.tagline}`}
  description={SITE_CONFIG.description}
  jsonLd={jsonLd}
>
  <div class="spine">
    <header class="cat-head">
      <p class="eyebrow mono">NCERT · CLASS I — XII · ENGLISH · हिंदी</p>
      <h1>The catalogue.</h1>
      <p class="lede">
        A flat directory of NCERT textbooks. Filter by class, subject, and
        medium; click a card to open chapters and the merged-book PDF on
        ncert.nic.in. No popups, no paywall, no required sign-in.
      </p>
    </header>

    <BookGrid client:load />
  </div>
</BaseLayout>

<style>
  .cat-head {
    padding-block: clamp(1.5rem, 4vw, 2.5rem) 1.25rem;
    border-bottom: 1px solid var(--rule);
  }
  .eyebrow {
    margin: 0 0 0.75rem;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-mute);
    font-feature-settings:
      'tnum' 1,
      'zero' 1,
      'ss20' 1,
      'calt' 0;
  }
  .cat-head h1 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2rem, 5vw, 3.25rem);
    letter-spacing: -0.005em;
    line-height: 1.05;
    color: var(--ink);
  }
  .lede {
    margin: 1rem 0 0;
    color: var(--ink-mute);
    max-width: 60ch;
    font-size: 1.0625rem;
  }
</style>
