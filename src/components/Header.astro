---
/*
 * Header — newsprint strip on Ink Block, 56px tall.
 *
 * Per the v2 brief:
 *   Left:    6px cinnabar band + `oriz · books` wordmark in Plex Serif
 *            (separator is the cinnabar middot, not the slash — the middot
 *            belongs to the catalogue-card metaphor's vocabulary)
 *   Center:  persistent search input, max 480px, Card-Bone fill, Graphite text,
 *            1px brass border. Placeholder cycles every 4 seconds between
 *            English and Hindi prompts. Cycle pauses on focus.
 *   Right:   Account chip (sign in / avatar) + filter-toggle hamburger that
 *            controls the home page filter rail on small screens.
 *
 * Inline scripts handle the placeholder cycle and the filter-toggle so the
 * chrome ships zero React.
 */
import Wordmark from './Wordmark.astro'
---

<header class="header">
  <div class="header-row">
    <a class="header-mark" href="/" aria-label="oriz · books — home">
      <span class="header-band" aria-hidden="true"></span>
      <Wordmark subtitle="books" size={18} />
    </a>

    <form class="header-search" role="search" action="/search/" method="get">
      <label for="header-q" class="sr-only">Search the catalogue</label>
      <input
        id="header-q"
        name="q"
        type="search"
        class="search-input"
        placeholder="Search by class, subject, or chapter…"
        autocomplete="off"
        data-cycle-placeholder
      />
    </form>

    <div class="header-right">
      <a href="/account/" class="header-chip" aria-label="Sign in or account">
        <span class="chip-dot" aria-hidden="true"></span>
        <span class="chip-label mono">SIGN IN</span>
      </a>
      <button
        type="button"
        class="header-toggle"
        aria-label="Toggle filter rail"
        aria-controls="filter-rail"
        aria-expanded="false"
        data-filter-toggle
      >
        <span class="toggle-bar" aria-hidden="true"></span>
        <span class="toggle-bar" aria-hidden="true"></span>
        <span class="toggle-bar" aria-hidden="true"></span>
      </button>
    </div>
  </div>
  <hr class="hairline" />
</header>

<script is:inline>
  ;(() => {
    const PLACEHOLDERS = [
      'Search by class, subject, or chapter…',
      'कक्षा, विषय या अध्याय खोजें…',
      'Find Class 10 Science…',
      'कक्षा 8 गणित…',
    ]
    const inputs = document.querySelectorAll('[data-cycle-placeholder]')
    if (!inputs.length) return
    let i = 0
    let paused = false
    for (const el of inputs) {
      el.addEventListener('focus', () => {
        paused = true
      })
      el.addEventListener('blur', () => {
        paused = false
      })
    }
    setInterval(() => {
      if (paused) return
      i = (i + 1) % PLACEHOLDERS.length
      for (const el of inputs) {
        if (el === document.activeElement) continue
        el.setAttribute('placeholder', PLACEHOLDERS[i])
      }
    }, 4000)
  })()
  ;(() => {
    const btn = document.querySelector('[data-filter-toggle]')
    if (!btn) return
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true'
      btn.setAttribute('aria-expanded', expanded ? 'false' : 'true')
      const rail = document.getElementById('filter-rail')
      if (rail) rail.toggleAttribute('data-open')
    })
  })()
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--paper);
  }
  .header-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    height: 56px;
    padding-inline: clamp(1rem, 4vw, 1.5rem);
    max-width: var(--container-spine);
    margin-inline: auto;
  }
  .header-mark {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    color: inherit;
    text-decoration: none;
  }
  .header-band {
    display: inline-block;
    width: 6px;
    height: 26px;
    background: var(--cinnabar);
    flex: none;
  }
  .header-search {
    display: flex;
    justify-content: center;
    min-width: 0;
  }
  .search-input {
    width: 100%;
    max-width: 480px;
    height: 32px;
    padding-inline: 0.875rem;
    background: var(--card);
    color: var(--graphite);
    border: 1px solid var(--brass);
    border-radius: 0;
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.2;
    -webkit-appearance: none;
    appearance: none;
  }
  .search-input::placeholder {
    color: var(--graphite-soft);
    opacity: 0.85;
  }
  .search-input:focus {
    outline: none;
    border-color: var(--cinnabar);
  }
  .header-right {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .header-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    height: 32px;
    padding-inline: 0.75rem;
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    font-feature-settings:
      'tnum' 1,
      'zero' 1,
      'ss20' 1,
      'calt' 0;
  }
  .header-chip:hover {
    border-color: var(--cinnabar);
    color: var(--cinnabar);
  }
  .chip-dot {
    width: 6px;
    height: 6px;
    background: var(--brass);
    flex: none;
  }
  .header-chip:hover .chip-dot {
    background: var(--cinnabar);
  }
  .header-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: transparent;
    border: 1px solid var(--rule);
    cursor: pointer;
    flex-direction: column;
    gap: 4px;
    border-radius: 0;
  }
  .header-toggle:hover {
    border-color: var(--cinnabar);
  }
  .toggle-bar {
    display: block;
    width: 14px;
    height: 1px;
    background: var(--ink);
  }
  .header-toggle:hover .toggle-bar {
    background: var(--cinnabar);
  }
  @media (max-width: 900px) {
    .header-toggle {
      display: inline-flex;
    }
  }
  @media (max-width: 640px) {
    .chip-label {
      display: none;
    }
    .header-chip {
      padding-inline: 0.5rem;
    }
    .header-row {
      grid-template-columns: auto 1fr auto;
    }
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
