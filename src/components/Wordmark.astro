---
/*
 * Wordmark — `oriz` set in IBM Plex Serif with a cinnabar hairline strike
 * through the `z` glyph. Copied verbatim from oriz-home/src/components/
 * Wordmark.astro EXCEPT the subtitle separator: per the v2 books brief the
 * separator is a Cinnabar middot (`·`), NOT a forward slash, because the
 * middot belongs to the catalogue-card metaphor's vocabulary.
 *
 * The strike colour is cinnabar on this site (vs vermilion on oriz-home).
 *
 *   <Wordmark subtitle="books" />   →  oriz · books
 *   <Wordmark subtitle="account" /> →  oriz · account
 *   <Wordmark />                    →  oriz (bare)
 */

interface Props {
  /** Sub-section name — rendered after a cinnabar middot in cinnabar italic. */
  subtitle?: string
  /** Display size in CSS pixels. */
  size?: number
  /** Wrap the mark in an <a href="/"> — defaults null (no link). */
  href?: string | null
  /** Render-only mode for the masthead (no link wrapper). */
  asHeading?: boolean
}

const { subtitle, size = 96, href = null, asHeading = false } = Astro.props
const Tag = asHeading ? 'h1' : ('div' as const)
---

{
  href ? (
    <a class="wordmark-link" href={href} aria-label={subtitle ? `oriz · ${subtitle}` : 'oriz'}>
      <Tag class="wordmark" style={`--wm-size: ${size}px;`}>
        <span class="wordmark-mark">
          <span class="wordmark-letter">o</span>
          <span class="wordmark-letter">r</span>
          <span class="wordmark-letter">i</span>
          <span class="wordmark-letter wordmark-z">
            z
            <span class="wordmark-strike" aria-hidden="true" />
          </span>
        </span>
        {subtitle && (
          <>
            <span class="wordmark-sep" aria-hidden="true">·</span>
            <span class="wordmark-sub">{subtitle}</span>
          </>
        )}
      </Tag>
    </a>
  ) : (
    <Tag class="wordmark" style={`--wm-size: ${size}px;`}>
      <span class="wordmark-mark">
        <span class="wordmark-letter">o</span>
        <span class="wordmark-letter">r</span>
        <span class="wordmark-letter">i</span>
        <span class="wordmark-letter wordmark-z">
          z
          <span class="wordmark-strike" aria-hidden="true" />
        </span>
      </span>
      {subtitle && (
        <>
          <span class="wordmark-sep" aria-hidden="true">·</span>
          <span class="wordmark-sub">{subtitle}</span>
        </>
      )}
    </Tag>
  )
}

<style>
  .wordmark-link {
    display: inline-block;
    color: inherit;
    text-decoration: none;
  }
  .wordmark {
    display: inline-flex;
    align-items: baseline;
    gap: 0.18em;
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--wm-size, 96px);
    line-height: 1;
    letter-spacing: 0.005em;
    color: var(--ink);
  }
  .wordmark-mark {
    display: inline-flex;
    align-items: baseline;
  }
  .wordmark-letter {
    position: relative;
    display: inline-block;
  }
  .wordmark-z {
    /* The glyph holds the strike — strike must extend 0.15em past on each side. */
    padding-inline: 0.15em;
  }
  .wordmark-strike {
    position: absolute;
    inset: 50% 0 auto 0;
    height: 0.04em;
    background: var(--cinnabar);
    transform: translateY(-50%);
    pointer-events: none;
  }
  @media (max-width: 480px) {
    .wordmark-strike {
      height: max(1px, 0.04em);
    }
  }
  .wordmark-sep {
    margin-inline: 0.22em 0.22em;
    color: var(--cinnabar);
    font-weight: 600;
  }
  .wordmark-sub {
    color: var(--cinnabar);
    font-style: italic;
    font-weight: 400;
  }
</style>
