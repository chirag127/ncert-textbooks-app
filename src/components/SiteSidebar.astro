---
/**
 * Books-specific sidebar — wraps the oriz-ui Sidebar React island with link
 * sections that make sense for an NCERT directory: All books, by Class,
 * by Subject, by Language, plus a Family section pointing at sibling sites.
 *
 * Sections come from the static metadata indexes shipped under
 * /public/data/metadata/{classes,subjects,languages}/. We list a curated
 * subset (the most useful classes/subjects) instead of every entry to keep
 * the rail short.
 */
import { Sidebar, FAMILY_SITES } from '@chirag127/oriz-ui'

const browseSection = {
  title: 'Browse',
  links: [
    { label: 'All books', href: '/' },
    { label: 'Search', href: '/search/' },
  ],
}

const classSection = {
  title: 'By class',
  links: [
    { label: 'Class 9', href: '/?class=class-9' },
    { label: 'Class 10', href: '/?class=class-10' },
    { label: 'Class 12', href: '/?class=class-12' },
  ],
}

const subjectSection = {
  title: 'By subject',
  links: [
    { label: 'Mathematics', href: '/?subject=mathematics' },
    { label: 'Science', href: '/?subject=science' },
    { label: 'Physics', href: '/?subject=physics' },
    { label: 'Chemistry', href: '/?subject=chemistry' },
    { label: 'Biology', href: '/?subject=biology' },
  ],
}

const languageSection = {
  title: 'By language',
  links: [
    { label: 'English', href: '/?language=english' },
    { label: 'Hindi', href: '/?language=hindi' },
  ],
}

const familySection = {
  title: 'oriz family',
  links: FAMILY_SITES.filter((s) => s.slug !== 'books').map((s) => ({
    label: `${s.emoji} ${s.name}`,
    href: s.url,
  })),
}

const sections = [browseSection, classSection, subjectSection, languageSection, familySection]
---

<aside class="site-sidebar-wrap">
  <Sidebar
    client:idle
    siteName="Books"
    siteSlug="books"
    sections={sections}
  />
</aside>

<style>
  .site-sidebar-wrap {
    /* The Sidebar component renders fixed/sticky on desktop and as a sheet on mobile;
       this wrapper just makes sure it sits in the grid column on desktop. */
    display: contents;
  }
</style>
