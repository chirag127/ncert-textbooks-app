---
/*
 * Footer — colophon paragraph + small mono row + family-sites menu.
 *
 * Per the v2 brief:
 *   1. Colophon paragraph (Plex Sans 13px, max 60ch):
 *        "Textbook content © NCERT, linked from ncert.nic.in. This site
 *         hosts no PDFs and runs no trackers."
 *   2. Mono row: build hash · last-scrape date · MIT licence · GitHub link
 *   3. Family menu: oriz · journal · blog · books · book-lore · pdf-tools
 *
 * No social icons, no newsletter signup, no emoji.
 *
 * Build metadata:
 *   PUBLIC_DEPLOY_TIME — set by GitHub Actions matrix-deploy
 *   PUBLIC_GIT_SHA     — short commit SHA
 *   PUBLIC_LAST_SCRAPE — last NCERT scrape ISO timestamp (set by data pipeline)
 * Each falls back gracefully when the env var is absent.
 */
import { FAMILY_SITES } from '~/lib/family'

const deployTime =
  import.meta.env.PUBLIC_DEPLOY_TIME ?? new Date().toISOString().slice(0, 16).replace('T', ' ')
const gitSha = import.meta.env.PUBLIC_GIT_SHA ?? 'dev'
const lastScrape = import.meta.env.PUBLIC_LAST_SCRAPE ?? deployTime

// Family menu order per the brief: oriz · journal · blog · books · book-lore · pdf-tools.
const FOOTER_FAMILY_SLUGS = ['home', 'journal', 'blog', 'books', 'book-lore', 'pdf-tools']
const familyMenu = FOOTER_FAMILY_SLUGS.map((slug) =>
  FAMILY_SITES.find((s) => s.slug === slug),
).filter((s): s is (typeof FAMILY_SITES)[number] => Boolean(s))
---

<footer class="footer">
  <hr class="hairline" />
  <div class="footer-inner">
    <p class="colophon">
      Textbook content © NCERT, linked from
      <a href="https://ncert.nic.in/">ncert.nic.in</a>. This site hosts no
      PDFs and runs no trackers.
    </p>

    <p class="meta-row mono">
      <span>BUILD <code>{gitSha}</code></span>
      <span class="sep" aria-hidden="true">·</span>
      <span>SYNC <time datetime={lastScrape}>{lastScrape}</time></span>
      <span class="sep" aria-hidden="true">·</span>
      <span>MIT</span>
      <span class="sep" aria-hidden="true">·</span>
      <a href="https://github.com/chirag127/oriz-books">GITHUB</a>
    </p>

    <nav class="family-menu mono" aria-label="oriz family">
      {
        familyMenu.map((s, i) => (
          <>
            {i > 0 && (
              <span class="sep" aria-hidden="true">
                ·
              </span>
            )}
            <a href={s.url}>{s.slug === 'home' ? 'oriz' : s.slug}</a>
          </>
        ))
      }
    </nav>
  </div>
</footer>

<style>
  .footer {
    margin-top: clamp(3rem, 8vw, 5rem);
    background: var(--paper);
  }
  .footer-inner {
    max-width: var(--container-spine);
    margin-inline: auto;
    padding: 1.5rem clamp(1.25rem, 4vw, 2rem) 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .colophon {
    margin: 0;
    color: var(--ink);
    font-size: 13px;
    line-height: 1.55;
    max-width: 60ch;
  }
  .colophon a {
    color: var(--cinnabar);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    text-decoration-color: color-mix(in oklab, var(--cinnabar) 50%, transparent);
  }
  .colophon a:hover {
    text-decoration-color: var(--cinnabar);
  }
  .meta-row {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    align-items: center;
    color: var(--ink-mute);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-feature-settings:
      'tnum' 1,
      'zero' 1,
      'ss20' 1,
      'calt' 0;
  }
  .meta-row code {
    font-family: var(--font-mono);
    color: var(--ink);
  }
  .meta-row a {
    color: var(--ink-mute);
    text-decoration: underline;
    text-decoration-color: var(--rule);
    text-underline-offset: 3px;
  }
  .meta-row a:hover {
    color: var(--cinnabar);
    text-decoration-color: var(--cinnabar);
  }
  .family-menu {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    color: var(--ink-mute);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-feature-settings:
      'tnum' 1,
      'zero' 1,
      'ss20' 1,
      'calt' 0;
  }
  .family-menu a {
    color: var(--ink-mute);
    text-decoration: none;
  }
  .family-menu a:hover {
    color: var(--cinnabar);
  }
  .sep {
    color: var(--rule);
  }
  .meta-row .sep,
  .family-menu .sep {
    color: var(--ink-mute);
    opacity: 0.5;
  }
</style>
